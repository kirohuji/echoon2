generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String    @id
  name                String
  email               String
  emailVerified       Boolean   @default(false)
  image               String?
  username            String?   @unique
  phoneNumber         String?   @unique
  phoneNumberVerified Boolean   @default(false)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  sessions            Session[]
  accounts            Account[]
  bindingConfig       UserBindingConfig?
  favoriteQuestions   FavoriteQuestion[]
  vocabularyWords     VocabularyWord[]
  practiceRecords     PracticeRecord[]
  practiceProgresses  PracticeProgress[]
  mockExamRecords     MockExamRecord[]
  dailyActivities     DailyActivity[]
  userPreference      UserPreference?
  fileReferences      FileReference[]

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

// ---- 题库域 ----

model QuestionBank {
  id            String   @id @default(cuid())
  name          String
  province      String
  language      String
  examType      String
  interviewForm String
  status        String   @default("active")
  topics        QuestionTopic[]
  userBindings  UserBindingConfig[]
  mockPapers    MockPaper[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  @@map("question_bank")
}

model QuestionTopic {
  id        String   @id @default(cuid())
  bank      QuestionBank @relation(fields: [bankId], references: [id])
  bankId    String
  code      String
  name      String
  sortOrder Int      @default(0)
  items     QuestionItem[]
  @@map("question_topic")
}

model QuestionItem {
  id                   String   @id @default(cuid())
  topic                QuestionTopic @relation(fields: [topicId], references: [id])
  topicId              String
  title                String
  difficulty           Int      @default(3)
  suggestedDurationSec Int      @default(120)
  masteryScore         Int      @default(0)
  keywords             String[]
  focusWords           String[]
  content              QuestionContent?
  favorites            FavoriteQuestion[]
  practiceRecords      PracticeRecord[]
  practiceProgresses   PracticeProgress[]
  mockPaperQuestions   MockPaperQuestion[]
  vocabularyWords      VocabularyWord[]
  questionAudios       QuestionAudio[]
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  @@index([topicId, difficulty])
  @@map("question_item")
}

model QuestionContent {
  id         String   @id @default(cuid())
  question   QuestionItem @relation(fields: [questionId], references: [id])
  questionId String   @unique
  promptEn   String   @db.Text
  promptZh   String   @db.Text
  answerEn   String   @db.Text
  answerZh   String   @db.Text
  summary    String   @db.Text
  @@map("question_content")
}

// ---- 学习行为域 ----

model UserBindingConfig {
  id            String   @id @default(cuid())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId        String   @unique
  province      String
  language      String
  examType      String
  interviewForm String
  bank          QuestionBank? @relation(fields: [bankId], references: [id])
  bankId        String?
  updatedAt     DateTime @updatedAt
  @@map("user_binding_config")
}

model FavoriteQuestion {
  id         String   @id @default(cuid())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  question   QuestionItem @relation(fields: [questionId], references: [id])
  questionId String
  createdAt  DateTime @default(now())
  @@unique([userId, questionId])
  @@index([userId, createdAt(sort: Desc)])
  @@map("favorite_question")
}

model VocabularyWord {
  id               String   @id @default(cuid())
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId           String
  term             String
  definition       String?
  sourceQuestion   QuestionItem? @relation(fields: [sourceQuestionId], references: [id])
  sourceQuestionId String?
  createdAt        DateTime @default(now())
  @@unique([userId, term])
  @@index([userId, createdAt(sort: Desc)])
  @@map("vocabulary_word")
}

model PracticeRecord {
  id         String   @id @default(cuid())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  question   QuestionItem @relation(fields: [questionId], references: [id])
  questionId String
  actionType String
  payload    Json?
  createdAt  DateTime @default(now())
  @@index([userId, createdAt(sort: Desc)])
  @@map("practice_record")
}

model PracticeProgress {
  id           String   @id @default(cuid())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       String
  question     QuestionItem @relation(fields: [questionId], references: [id])
  questionId   String
  masteryScore Int      @default(0)
  seenAt       DateTime?
  updatedAt    DateTime @updatedAt
  @@unique([userId, questionId])
  @@map("practice_progress")
}

// ---- 模考域 ----

model MockPaper {
  id               String   @id @default(cuid())
  bank             QuestionBank @relation(fields: [bankId], references: [id])
  bankId           String
  title            String
  paperType        String   @default("standard")
  suggestedMinutes Int      @default(30)
  focus            String[]
  questions        MockPaperQuestion[]
  examRecords      MockExamRecord[]
  createdAt        DateTime @default(now())
  @@map("mock_paper")
}

model MockPaperQuestion {
  id         String   @id @default(cuid())
  paper      MockPaper @relation(fields: [paperId], references: [id])
  paperId    String
  question   QuestionItem @relation(fields: [questionId], references: [id])
  questionId String
  sortOrder  Int      @default(0)
  @@map("mock_paper_question")
}

model MockExamRecord {
  id       String   @id @default(cuid())
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId   String
  paper    MockPaper @relation(fields: [paperId], references: [id])
  paperId  String
  score    Int
  weakness String[]
  takenAt  DateTime @default(now())
  @@index([userId, takenAt(sort: Desc)])
  @@map("mock_exam_record")
}

// ---- 用户看板域 ----

model DailyActivity {
  id       String   @id @default(cuid())
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId   String
  date     DateTime @db.Date
  count    Int      @default(1)
  @@unique([userId, date])
  @@map("daily_activity")
}

model UserPreference {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String   @unique
  autoPlay  Boolean  @default(false)
  language  String   @default("zh-CN")
  theme     String   @default("system")
  updatedAt DateTime @updatedAt
  @@map("user_preference")
}

model MembershipPlan {
  id        String   @id @default(cuid())
  name      String
  price     Int
  period    String
  features  String[]
  sortOrder Int      @default(0)
  @@map("membership_plan")
}

// ---- 文件资产域 ----

enum FileAssetGroup {
  avatar
  library
  tts
}

enum FileAssetStatus {
  active
  deleted
}

model FileAsset {
  id               String          @id @default(cuid())
  sha256           String          @unique
  bucket           String
  region           String
  cosKey           String          @unique
  group            FileAssetGroup
  size             Int
  mimeType         String
  filename         String
  status           FileAssetStatus @default(active)
  refCount         Int             @default(0)
  lastReferencedAt DateTime?
  createdAt        DateTime        @default(now())
  references       FileReference[]
  questionAudios   QuestionAudio[]
  @@index([group, status, createdAt(sort: Desc)])
  @@index([status, refCount, createdAt])
  @@map("file_asset")
}

model FileReference {
  id        String    @id @default(cuid())
  asset     FileAsset @relation(fields: [assetId], references: [id])
  assetId   String
  bizType   String
  bizId     String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  createdAt DateTime  @default(now())
  @@unique([assetId, bizType, bizId, userId])
  @@index([bizType, bizId, userId])
  @@map("file_reference")
}

// ---- TTS 音频缓存域 ----

enum TtsProvider {
  minimax
  cartesia
}

/// 题目音频缓存：同一题目 + 相同配置只生成一次，之后直接复用
model QuestionAudio {
  id             String      @id @default(cuid())
  question       QuestionItem @relation(fields: [questionId], references: [id])
  questionId     String
  /// provider+model+voiceId+params 的 SHA1 哈希，保证唯一性
  configHash     String
  provider       TtsProvider
  model          String
  voiceId        String?
  mimeType       String
  asset          FileAsset   @relation(fields: [assetId], references: [id])
  assetId        String
  wordTimestamps Json?
  createdAt      DateTime    @default(now())
  @@unique([questionId, configHash])
  @@index([questionId])
  @@index([assetId])
  @@map("question_audio")
}
